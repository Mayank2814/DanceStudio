const express = require('express');
const router = express.Router();
const { body, validationResult } = require('express-validator');
const Class = require('../models/Class');
const User = require('../models/User');
const { protect, admin } = require('../middleware/auth');

// All routes are protected and require admin role
router.use(protect);
router.use(admin);

// @route   POST /api/admin/classes
// @desc    Create a new dance class
// @access  Private/Admin
router.post('/classes', [
  body('title').trim().notEmpty().withMessage('Title is required'),
  body('description').trim().notEmpty().withMessage('Description is required'),
  body('instructor').trim().notEmpty().withMessage('Instructor name is required'),
  body('danceStyle').optional().isIn(['Ballet', 'Hip Hop', 'Contemporary', 'Jazz', 'Salsa', 'Ballroom', 'Breakdance', 'Other']).withMessage('Invalid dance style'),
  body('style').optional().isIn(['Ballet', 'Hip Hop', 'Contemporary', 'Jazz', 'Salsa', 'Ballroom', 'Breakdance', 'Other']).withMessage('Invalid dance style'),
  body('level').isIn(['Beginner', 'Intermediate', 'Advanced']).withMessage('Invalid level'),
  // Allow schedule to be either a string (free text) or an object. We require schedule but do custom validation below.
  body('schedule').notEmpty().withMessage('Schedule is required'),
  body('duration').isInt({ min: 1 }).withMessage('Duration must be a positive number'),
  body('maxCapacity').optional().isInt({ min: 1 }).withMessage('Max capacity must be a positive number'),
  body('capacity').optional().isInt({ min: 1 }).withMessage('Capacity must be a positive number'),
  body('price').isFloat({ min: 0 }).withMessage('Price must be a positive number')
], async (req, res) => {
  try {
    const errors = validationResult(req);
    if (!errors.isEmpty()) {
      return res.status(400).json({
        success: false,
        errors: errors.array()
      });
    }

    // Normalize incoming fields to match the schema
    const danceStyle = req.body.danceStyle || req.body.style;
    const maxCapacity = req.body.maxCapacity || req.body.capacity;

    // Convert price from rupees (frontend) to paise (backend canonical)
    const rawPrice = parseFloat(req.body.price);
    const price = Number.isFinite(rawPrice) ? Math.round(rawPrice * 100) : 0;

    const classData = {
      title: req.body.title,
      description: req.body.description,
      instructor: req.body.instructor,
      danceStyle,
      level: req.body.level,
      schedule: req.body.schedule, // can be string or object
      duration: parseInt(req.body.duration, 10),
      maxCapacity: parseInt(maxCapacity, 10) || 20,
      price,
      createdBy: req.user._id
    };

    const danceClass = await Class.create(classData);

    res.status(201).json({
      success: true,
      data: danceClass
    });
  } catch (error) {
    console.error(error);
    res.status(500).json({
      success: false,
      message: 'Server error creating class'
    });
  }
});

// @route   GET /api/admin/classes
// @desc    Get all classes (admin view)
// @access  Private/Admin
router.get('/classes', async (req, res) => {
  try {
    const classes = await Class.find()
      .populate('createdBy', 'name email')
      .populate('enrolledStudents', 'name email')
      .sort('-createdAt');

    res.json({
      success: true,
      count: classes.length,
      data: classes
    });
  } catch (error) {
    console.error(error);
    res.status(500).json({
      success: false,
      message: 'Server error fetching classes'
    });
  }
});

// @route   GET /api/admin/classes/:id
// @desc    Get single class by ID
// @access  Private/Admin
router.get('/classes/:id', async (req, res) => {
  try {
    const danceClass = await Class.findById(req.params.id)
      .populate('createdBy', 'name email')
      .populate('enrolledStudents', 'name email');

    if (!danceClass) {
      return res.status(404).json({
        success: false,
        message: 'Class not found'
      });
    }

    res.json({
      success: true,
      data: danceClass
    });
  } catch (error) {
    console.error(error);
    res.status(500).json({
      success: false,
      message: 'Server error fetching class'
    });
  }
});

// @route   PUT /api/admin/classes/:id
// @desc    Update a dance class
// @access  Private/Admin
router.put('/classes/:id', async (req, res) => {
  try {
    let danceClass = await Class.findById(req.params.id);

    if (!danceClass) {
      return res.status(404).json({
        success: false,
        message: 'Class not found'
      });
    }

    // Don't allow updating enrolledStudents directly
    delete req.body.enrolledStudents;
    delete req.body.createdBy;

    // Normalize fields: accept `style` and `capacity` from client
    if (req.body.style) {
      req.body.danceStyle = req.body.style;
      delete req.body.style;
    }
    if (req.body.capacity) {
      req.body.maxCapacity = parseInt(req.body.capacity, 10);
      delete req.body.capacity;
    }

    // Convert provided price in rupees to paise (backend stores paise)
    if (req.body.price !== undefined && req.body.price !== null && req.body.price !== '') {
      const raw = Number(req.body.price);
      if (!Number.isNaN(raw)) {
        req.body.price = Math.round(raw * 100);
      } else {
        delete req.body.price;
      }
    }

    danceClass = await Class.findByIdAndUpdate(
      req.params.id,
      req.body,
      {
        new: true,
        runValidators: true
      }
    );

    res.json({
      success: true,
      data: danceClass
    });
  } catch (error) {
    console.error(error);
    res.status(500).json({
      success: false,
      message: 'Server error updating class'
    });
  }
});

// @route   DELETE /api/admin/classes/:id
// @desc    Delete a dance class
// @access  Private/Admin
router.delete('/classes/:id', async (req, res) => {
  try {
    const danceClass = await Class.findById(req.params.id);

    if (!danceClass) {
      return res.status(404).json({
        success: false,
        message: 'Class not found'
      });
    }

    await Class.findByIdAndDelete(req.params.id);

    res.json({
      success: true,
      message: 'Class deleted successfully'
    });
  } catch (error) {
    console.error(error);
    res.status(500).json({
      success: false,
      message: 'Server error deleting class'
    });
  }
});

