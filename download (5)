    });
  }
});

// @route   PUT /api/admin/instructor-requests/:id/approve
// @desc    Approve an instructor request (promote user to instructor)
// @access  Private/Admin
router.put('/instructor-requests/:id/approve', async (req, res) => {
  try {
    const user = await User.findById(req.params.id);
    if (!user) {
      return res.status(404).json({ success: false, message: 'User not found' });
    }
    user.role = 'instructor';
    await user.save();
    res.json({ success: true, data: user });
  } catch (error) {
    console.error(error);
    res.status(500).json({ success: false, message: 'Server error approving instructor' });
  }
});

// @route   PUT /api/admin/instructor-requests/:id/reject
// @desc    Reject an instructor request (revert to user)
// @access  Private/Admin
router.put('/instructor-requests/:id/reject', async (req, res) => {
  try {
    const user = await User.findById(req.params.id);
    if (!user) {
      return res.status(404).json({ success: false, message: 'User not found' });
    }
    user.role = 'user';
    await user.save();
    res.json({ success: true, data: user });
  } catch (error) {
    console.error(error);
    res.status(500).json({ success: false, message: 'Server error rejecting instructor' });
  }
});

module.exports = router;
